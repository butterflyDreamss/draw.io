          <mxGeometry height="100" width="100" x="133" y="533" as="geometry" />
        </mxCell>
        <mxCell id="GIb7ujWcDjvPRv6p48lb-43" parent="1" style="ellipse;whiteSpace=wrap;html=1;strokeWidth=2;fillWeight=2;hachureGap=8;fillColor=#990000;fillStyle=dots;sketch=1;" value="" vertex="1">
          <mxGeometry height="90" width="106" x="198" y="598" as="geometry" />
        </mxCell>
        <mxCell id="GIb7ujWcDjvPRv6p48lb-44" parent="1" style="shape=singleArrow;whiteSpace=wrap;html=1;rotation=-228;" value="面向" vertex="1">
          <mxGeometry height="60" width="100" x="76" y="619" as="geometry" />
        </mxCell>
        <mxCell id="GIb7ujWcDjvPRv6p48lb-45" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;autosize=1;resizable=0;" value="第一轮封锁结束" vertex="1">
          <mxGeometry height="30" width="110" x="128" y="738" as="geometry" />
        </mxCell>
        <mxCell id="GIb7ujWcDjvPRv6p48lb-46" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=17;" value="技能顺序:&lt;div&gt;1.电流脉冲+焚火一线:这次需要T接力承伤总共大概18层,被点名的远程跑到BOSS面向的扇形里(即大团右手边的扇形)&lt;/div&gt;&lt;div&gt;2.旋转射线:boss周围出现4个激光炮台,发射持续性激光并旋转(30s&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;),二段跳可过线,需要跳过4条射线可以扶摇/二段跳+3个小轻功 正好4次,此时可以打挡板修颜色,缺口过来也可以打缺口.&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3.第二次封锁&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4.在封锁之前需要把蓝色挡板修到BOSS面向的逆时针一格,即缺口的对面.(可以由T来检查颜色)&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="270" width="380" x="397" y="468" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
