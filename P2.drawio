        <mxCell id="GIb7ujWcDjvPRv6p48lb-28" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;rounded=0;fontSize=17;" value="技能顺序:&lt;div&gt;1.玄磁激振+4圈重叠承伤&lt;/div&gt;&lt;div&gt;2.第二次旋转射线&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;3.第三次封锁&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;4.在封锁之前需要把蓝色挡板修到BOSS面向&lt;/span&gt;&lt;/div&gt;" vertex="1">
